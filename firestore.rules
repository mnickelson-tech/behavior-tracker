rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isTeacher() {
      // Teacher frontend requires @conroeisd.net sign in; this is additional safety.
      return isSignedIn() && request.auth.token.email.toLowerCase().endsWith('@conroeisd.net');
    }

    function isSpedAdmin() {
      // Keep this in sync with dashboard.js SPED_ADMIN_EMAILS list.
      return isSignedIn() && [        'ektodd@conroeisd.net',
        'mhenthorn@conroeisd.net',
        'dpreuss@conroeisd.net',
        'mnickelson@conroeisd.net'
      ].includes(request.auth.token.email.toLowerCase());
    }

    match /teacherStudents/{uid} {
      allow read, write: if isTeacher() && request.auth.uid == uid;
    }

    match /teacherFavorites/{uid} {
      allow read, write: if isTeacher() && request.auth.uid == uid;
    }

    match /logs/{logId} {
      allow create: if isTeacher() && request.auth.uid != null;
      allow read: if isSpedAdmin() || (isTeacher() && resource.data.teacherUid == request.auth.uid);
      allow update, delete: if isSpedAdmin();
    }

    match /behaviors/{behaviorId} {
      // Public behavior list for all signed-in teachers; admins can also write.
      allow read: if true;
      allow write: if isSpedAdmin();
    }
  }
}
